@model IReadOnlyList<CategoryDto>
@{
    ViewData["Title"] = "Categories";
    var activeCount = Model.Count(c => c.IsActive);
}

<div class="customers-page-header mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <p class="text-muted mb-1 small text-uppercase fw-semibold letter-spacing">Catalog</p>
            <h2 class="fw-bold mb-0">@Model.Count categor@(Model.Count == 1 ? "y" : "ies")</h2>
        </div>
        <a asp-action="Create" class="btn btn-admin-create">
            <i class="bi bi-plus-lg"></i> Add category
        </a>
    </div>
</div>

<div class="admin-table-card orders-table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle orders-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Products</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr class="orders-table__row">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="category-table__icon"><i class="bi bi-tag-fill"></i></span>
                            <strong>@c.Name</strong>
                        </div>
                    </td>
                    <td class="text-muted">@(string.IsNullOrWhiteSpace(c.Description) ? "—" : c.Description)</td>
                    <td>
                        <span class="orders-table__items">@c.ProductCount</span>
                    </td>
                    <td>
                        <partial name="_CustomerStatusBadge" model="c.IsActive" />
                    </td>
                    <td class="text-end">
                        <div class="admin-action-group">
                            <a asp-action="Edit" asp-route-id="@c.Id" class="admin-action-btn admin-action-btn--edit" title="Edit @c.Name">
                                <i class="bi bi-pencil-square"></i>
                                <span>Edit</span>
                            </a>
                            <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="admin-action-form"
                                  onsubmit="return confirm('Delete category &quot;@c.Name&quot;?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="admin-action-btn admin-action-btn--delete" title="Delete @c.Name">
                                    <i class="bi bi-trash3"></i>
                                    <span>Delete</span>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="orders-empty text-center py-5">
        <i class="bi bi-tags display-4 text-muted"></i>
        <p class="text-muted mt-3 mb-3">No categories yet.</p>
        <a asp-action="Create" class="btn btn-admin-create">Create your first category</a>
    </div>
}
