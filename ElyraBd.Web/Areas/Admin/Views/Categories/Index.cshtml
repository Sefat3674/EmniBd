@model IReadOnlyList<CategoryDto>
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between mb-3">
    <p class="text-muted mb-0">Manage product categories</p>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Add category</a>
</div>

<div class="admin-table-card">
    <table class="table mb-0">
        <thead class="table-light"><tr><th>Name</th><th>Description</th><th>Active</th><th></th></tr></thead>
        <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td><strong>@c.Name</strong></td>
                <td class="text-muted">@c.Description</td>
                <td>@(c.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline" onsubmit="return confirm('Delete category?');">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
