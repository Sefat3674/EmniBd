@model IReadOnlyList<ProductDto>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">@Model.Count products</p>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Add product</a>
</div>

<div class="admin-table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>
                        <strong>@p.Name</strong>
                        @if (p.IsFeatured) { <span class="badge bg-primary ms-1">Featured</span> }
                        @if (p.HasDiscount) { <span class="badge bg-danger ms-1">-@p.DiscountPercent%</span> }
                    </td>
                    <td>@p.CategoryName</td>
                    <td>৳@p.SalePrice.ToString("N2")</td>
                    <td>@p.Stock</td>
                    <td>
                        @if (p.IsActive) { <span class="badge text-bg-success">Active</span> }
                        else { <span class="badge text-bg-secondary">Inactive</span> }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <form asp-action="ToggleActive" asp-route-id="@p.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Toggle</button>
                        </form>
                        <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this product?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
