@model IReadOnlyList<CustomerSummary>
@{
    ViewData["Title"] = "Customers";
    var activeCount = Model.Count(c => c.IsActive);
    var inactiveCount = Model.Count - activeCount;
}

<div class="customers-page-header mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
        <div>
            <p class="text-muted mb-1 small text-uppercase fw-semibold letter-spacing">Customer management</p>
            <h2 class="fw-bold mb-0">@Model.Count customer@(Model.Count == 1 ? "" : "s")</h2>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <span class="customer-stat-pill customer-stat-pill--active">
                <i class="bi bi-person-check-fill"></i> @activeCount active
            </span>
            <span class="customer-stat-pill customer-stat-pill--inactive">
                <i class="bi bi-person-dash"></i> @inactiveCount inactive
            </span>
        </div>
    </div>
</div>

<div class="admin-table-card orders-table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle orders-table customers-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Registered</th>
                    <th>Last login</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr class="orders-table__row">
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="customers-table__avatar">@c.FullName.FirstOrDefault()</span>
                            <span class="fw-semibold">@c.FullName</span>
                        </div>
                    </td>
                    <td class="text-muted">@c.Email</td>
                    <td>@c.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td class="text-muted">@(c.LastLoginAt?.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt") ?? "—")</td>
                    <td>
                        <partial name="_CustomerStatusBadge" model="c.IsActive" />
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="orders-empty text-center py-5">
        <i class="bi bi-people display-4 text-muted"></i>
        <p class="text-muted mt-3 mb-0">No customers registered yet.</p>
    </div>
}
