@model OrderDetailDto
@using ElyraBd.Core.Enums
@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";
    var canUpdate = Model.Status is not (OrderStatus.Delivered or OrderStatus.Cancelled);
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="admin-table-card p-4 mb-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-person-vcard text-primary"></i> Customer</h5>
            <p class="mb-1"><strong>@Model.CustomerName</strong> — @Model.CustomerEmail</p>
            <p class="mb-1">@Model.CustomerPhone</p>
            <p class="mb-0 text-muted">@Model.AddressLine, @Model.City @Model.PostalCode</p>
        </div>

        <div class="admin-table-card orders-table-card">
            <div class="table-responsive">
                <table class="table mb-0 orders-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="fw-semibold">@item.ProductName</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">৳@item.UnitPrice.ToString("N2")</td>
                                <td class="text-end">৳@item.LineTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr><td colspan="3" class="text-end text-muted">Subtotal</td><td class="text-end">৳@Model.SubTotal.ToString("N2")</td></tr>
                        <tr><td colspan="3" class="text-end text-muted">Delivery</td><td class="text-end">৳@Model.DeliveryCharge.ToString("N2")</td></tr>
                        @if (Model.DiscountAmount > 0)
                        {
                            <tr><td colspan="3" class="text-end text-success">Discount</td><td class="text-end text-success">-৳@Model.DiscountAmount.ToString("N2")</td></tr>
                        }
                        <tr class="fw-bold"><td colspan="3" class="text-end">Total</td><td class="text-end fs-5 text-primary">৳@Model.TotalAmount.ToString("N2")</td></tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="admin-table-card p-4 mb-3 order-detail-status-card">
            <h5 class="fw-bold mb-3">Order status</h5>
            <div class="mb-3">
                <partial name="_OrderStatusBadge" model="Model.Status" />
            </div>
            <p class="small text-muted mb-0">
                <i class="bi bi-credit-card"></i> @Model.PaymentMethod — @Model.PaymentStatus
            </p>

            @if (canUpdate)
            {
                <form asp-action="UpdateStatus" method="post" class="mt-4 pt-3 border-top">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="OrderId" value="@Model.Id" />
                    <div class="mb-2">
                        <label class="form-label small fw-semibold">Update status</label>
                        <select name="Status" class="form-select orders-status-select" asp-items="ViewBag.StatusList"></select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Note (optional)</label>
                        <input type="text" name="Note" class="form-control form-control-sm" placeholder="e.g. Handed to courier" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Update status</button>
                </form>

                <form asp-action="Cancel" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="text" name="reason" class="form-control form-control-sm mb-2" placeholder="Cancellation reason" required />
                    <button type="submit" class="btn btn-outline-danger w-100">Cancel order</button>
                </form>
            }
        </div>

        <div class="admin-table-card p-4">
            <h6 class="fw-bold mb-4"><i class="bi bi-signpost-split text-primary"></i> Tracking timeline</h6>
            <div class="admin-order-timeline">
                @foreach (var step in Model.Timeline)
                {
                    var stepClass = step.Status.ToString().ToLowerInvariant();
                    var icon = step.Status switch
                    {
                        OrderStatus.Pending => "bi-hourglass-split",
                        OrderStatus.Processing => "bi-gear-wide-connected",
                        OrderStatus.Packed => "bi-box-seam",
                        OrderStatus.Shipped => "bi-truck",
                        OrderStatus.Delivered => "bi-check-lg",
                        OrderStatus.Cancelled => "bi-x-lg",
                        _ => "bi-circle"
                    };
                    <div class="admin-timeline-step admin-timeline-step--@stepClass @(step.IsCompleted ? "is-completed" : "") @(step.IsCurrent ? "is-current" : "")">
                        <div class="admin-timeline-step__dot">
                            <i class="bi @icon"></i>
                        </div>
                        <div>
                            <div class="admin-timeline-step__label">@step.StatusLabel</div>
                            @if (step.IsCompleted && step.ChangedAt != default)
                            {
                                <div class="admin-timeline-step__time">@step.ChangedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</div>
                            }
                            @if (!string.IsNullOrEmpty(step.Note))
                            {
                                <div class="admin-timeline-step__time">@step.Note</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to orders</a>
</div>
