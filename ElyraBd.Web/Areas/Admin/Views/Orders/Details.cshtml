@model OrderDetailDto
@using ElyraBd.Core.Enums
@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";
    var canUpdate = Model.Status is not (OrderStatus.Delivered or OrderStatus.Cancelled);
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="admin-table-card p-4 mb-4">
            <h5 class="fw-bold mb-3">Customer</h5>
            <p class="mb-1"><strong>@Model.CustomerName</strong> — @Model.CustomerEmail</p>
            <p class="mb-1">@Model.CustomerPhone</p>
            <p class="mb-0 text-muted">@Model.AddressLine, @Model.City @Model.PostalCode</p>
        </div>

        <div class="admin-table-card">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Price</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">৳@item.UnitPrice.ToString("N2")</td>
                                <td class="text-end">৳@item.LineTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr><td colspan="3" class="text-end">Subtotal</td><td class="text-end">৳@Model.SubTotal.ToString("N2")</td></tr>
                        <tr><td colspan="3" class="text-end">Delivery</td><td class="text-end">৳@Model.DeliveryCharge.ToString("N2")</td></tr>
                        @if (Model.DiscountAmount > 0)
                        {
                            <tr><td colspan="3" class="text-end">Discount</td><td class="text-end text-success">-৳@Model.DiscountAmount.ToString("N2")</td></tr>
                        }
                        <tr class="fw-bold"><td colspan="3" class="text-end">Total</td><td class="text-end">৳@Model.TotalAmount.ToString("N2")</td></tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="admin-table-card p-4 mb-3">
            <h5 class="fw-bold mb-3">Status</h5>
            <p>Current: <span class="badge @Badge(Model.Status) fs-6">@Model.Status</span></p>
            <p class="small text-muted">Payment: @Model.PaymentMethod — @Model.PaymentStatus</p>

            @if (canUpdate)
            {
                <form asp-action="UpdateStatus" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="OrderId" value="@Model.Id" />
                    <div class="mb-2">
                        <label class="form-label small">Update status</label>
                        <select name="Status" class="form-select" asp-items="ViewBag.StatusList"></select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Note (optional)</label>
                        <input type="text" name="Note" class="form-control form-control-sm" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Update status</button>
                </form>

                <form asp-action="Cancel" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="text" name="reason" class="form-control form-control-sm mb-2" placeholder="Cancellation reason" required />
                    <button type="submit" class="btn btn-outline-danger w-100">Cancel order</button>
                </form>
            }
        </div>

        <div class="admin-table-card p-4">
            <h6 class="fw-bold mb-3">Timeline</h6>
            @foreach (var step in Model.Timeline)
            {
                <div class="small mb-2 @(step.IsCompleted ? "text-dark" : "text-muted")">
                    <i class="bi @(step.IsCompleted ? "bi-check-circle-fill text-success" : "bi-circle")"></i>
                    @step.StatusLabel
                    @if (step.ChangedAt != default)
                    {
                        <span class="text-muted">— @step.ChangedAt.ToLocalTime().ToString("dd MMM HH:mm")</span>
                    }
                </div>
            }
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">← Back to orders</a>
</div>

@functions {
    string Badge(OrderStatus s) => s switch
    {
        OrderStatus.Delivered => "text-bg-success",
        OrderStatus.Shipped => "text-bg-info",
        OrderStatus.Packed => "text-bg-primary",
        OrderStatus.Processing => "text-bg-warning",
        OrderStatus.Cancelled => "text-bg-secondary",
        _ => "text-bg-secondary"
    };
}
