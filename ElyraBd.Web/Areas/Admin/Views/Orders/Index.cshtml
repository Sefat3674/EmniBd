@model IReadOnlyList<OrderSummaryDto>
@using ElyraBd.Core.Enums
@{
    ViewData["Title"] = "Orders";
    var status = ViewBag.Status as OrderStatus?;
}

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label small mb-0">Filter by status</label>
        <select name="status" class="form-select form-select-sm" asp-items="ViewBag.StatusList" onchange="this.form.submit()"></select>
    </div>
    <div class="col-auto">
        <span class="text-muted">@Model.Count order(s)</span>
    </div>
</form>

<div class="admin-table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Order #</th>
                    <th>Date</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td><strong>@order.OrderNumber</strong></td>
                    <td>@order.OrderDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td>@order.ItemCount</td>
                    <td>৳@order.TotalAmount.ToString("N2")</td>
                    <td><span class="badge @Badge(order.Status)">@order.Status</span></td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Manage</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <p class="text-muted text-center py-4">No orders found.</p>
}

@functions {
    string Badge(OrderStatus s) => s switch
    {
        OrderStatus.Delivered => "text-bg-success",
        OrderStatus.Shipped => "text-bg-info",
        OrderStatus.Packed => "text-bg-primary",
        OrderStatus.Processing => "text-bg-warning",
        OrderStatus.Cancelled => "text-bg-secondary",
        _ => "text-bg-secondary"
    };
}
