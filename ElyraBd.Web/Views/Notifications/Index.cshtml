@model IReadOnlyList<NotificationDto>
@{
    ViewData["Title"] = "Notifications";
}
<link rel="stylesheet" href="~/css/shop.css" asp-append-version="true" />

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold mb-0">Notifications</h1>
        @if (Model.Any(n => !n.IsRead))
        {
            <form asp-action="MarkAllRead" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-primary">Mark all as read</button>
            </form>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bell display-1"></i>
            <p class="mt-3">No notifications yet.</p>
        </div>
    }
    else
    {
        @foreach (var n in Model)
        {
            <div class="card border-0 shadow-sm mb-2 @(n.IsRead ? "" : "border-start border-primary border-4")">
                <div class="card-body d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="fw-bold mb-1">@n.Title</h6>
                        <p class="mb-1">@n.Message</p>
                        <small class="text-muted">@n.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</small>
                        @if (n.OrderId.HasValue)
                        {
                            <div class="mt-2">
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@n.OrderId" class="btn btn-sm btn-outline-primary">View order</a>
                            </div>
                        }
                    </div>
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkRead" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@n.Id" />
                            <button type="submit" class="btn btn-sm btn-link">Mark read</button>
                        </form>
                    }
                </div>
            </div>
        }
    }
</div>
