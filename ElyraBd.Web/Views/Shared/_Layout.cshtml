<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ElyraBd</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ElyraBd.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="elyra-header" id="elyraHeader">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand elyra-brand" asp-controller="Home" asp-action="Index">
                    <span class="elyra-brand-mark">E</span>
                    Elyra<span class="elyra-brand-accent">Bd</span>
                </a>
                <button class="navbar-toggler elyra-nav-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-lg-center gap-lg-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-none d-lg-block">
                                <span class="elyra-user-pill">
                                    <i class="bi bi-person-circle"></i>
                                    @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-elyra-ghost btn-sm">
                                        <i class="bi bi-box-arrow-right"></i> Sign out
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link elyra-nav-link" asp-controller="Account" asp-action="Login">Sign in</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-elyra-cta btn-sm" asp-controller="Account" asp-action="Register">
                                    Get started <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="elyra-main">
        @RenderBody()
    </main>

    <footer class="elyra-footer">
        <div class="container">
            <div class="row align-items-center gy-3">
                <div class="col-md-6 text-center text-md-start">
                    <a asp-controller="Home" asp-action="Index" class="elyra-footer-brand">
                        <span class="elyra-brand-mark">E</span> Elyra<span class="elyra-brand-accent">Bd</span>
                    </a>
                    <p class="elyra-footer-tagline mb-0">Modern e-commerce for Bangladesh</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <p class="mb-0 elyra-footer-copy">&copy; @DateTime.UtcNow.Year ElyraBd. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
