@* Floating product category animations for Login / Register *@
<div class="auth-products-scene" aria-hidden="true">
    @* Orbiting products (right side of brand panel) *@
    <div class="auth-orbit-hub">
        <div class="auth-orbit-ring"></div>
        <div class="auth-orbit-item auth-orbit-item-1">
            <div class="auth-product-bubble theme-cosmetics">
                <i class="bi bi-palette-fill"></i>
                <span>Cosmetics</span>
            </div>
        </div>
        <div class="auth-orbit-item auth-orbit-item-2">
            <div class="auth-product-bubble theme-fashion">
                <i class="bi bi-handbag-fill"></i>
                <span>Dresses</span>
            </div>
        </div>
        <div class="auth-orbit-item auth-orbit-item-3">
            <div class="auth-product-bubble theme-household">
                <i class="bi bi-house-heart-fill"></i>
                <span>Home</span>
            </div>
        </div>
        <div class="auth-orbit-item auth-orbit-item-4">
            <div class="auth-product-bubble theme-skincare">
                <i class="bi bi-droplet-fill"></i>
                <span>Skincare</span>
            </div>
        </div>
    </div>

    @* Free-floating product cards *@
    <div class="auth-float-card theme-cosmetics auth-float-1">
        <div class="auth-float-card-visual">
            <i class="bi bi-stars"></i>
        </div>
        <div class="auth-float-card-body">
            <span class="auth-float-tag">New</span>
            <strong>Lipstick Set</strong>
            <small>৳ 890</small>
        </div>
    </div>

    <div class="auth-float-card theme-fashion auth-float-2">
        <div class="auth-float-card-visual">
            <i class="bi bi-handbag"></i>
        </div>
        <div class="auth-float-card-body">
            <span class="auth-float-tag hot">Hot</span>
            <strong>Summer Dress</strong>
            <small>৳ 2,450</small>
        </div>
    </div>

    <div class="auth-float-card theme-household auth-float-3">
        <div class="auth-float-card-visual">
            <i class="bi bi-lamp-fill"></i>
        </div>
        <div class="auth-float-card-body">
            <strong>Home Essentials</strong>
            <small>৳ 1,299</small>
        </div>
    </div>

    <div class="auth-float-card theme-skincare auth-float-4">
        <div class="auth-float-card-visual">
            <i class="bi bi-droplet-half"></i>
        </div>
        <div class="auth-float-card-body">
            <strong>Face Serum</strong>
            <small>৳ 1,650</small>
        </div>
    </div>

    <div class="auth-float-card theme-fashion auth-float-5">
        <div class="auth-float-card-visual mini">
            <i class="bi bi-gem"></i>
        </div>
        <div class="auth-float-card-body compact">
            <strong>Jewelry</strong>
        </div>
    </div>

    <div class="auth-float-card theme-household auth-float-6">
        <div class="auth-float-card-visual mini">
            <i class="bi bi-cup-hot-fill"></i>
        </div>
        <div class="auth-float-card-body compact">
            <strong>Kitchen</strong>
        </div>
    </div>

    @* Sparkle particles *@
    <span class="auth-sparkle auth-sparkle-1"></span>
    <span class="auth-sparkle auth-sparkle-2"></span>
    <span class="auth-sparkle auth-sparkle-3"></span>
    <span class="auth-sparkle auth-sparkle-4"></span>
    <span class="auth-sparkle auth-sparkle-5"></span>
</div>

<div class="auth-category-ticker" aria-hidden="true">
    <div class="auth-category-track">
        <span><i class="bi bi-palette"></i> Cosmetics</span>
        <span><i class="bi bi-handbag"></i> Women's Dresses</span>
        <span><i class="bi bi-house"></i> Household</span>
        <span><i class="bi bi-droplet"></i> Skincare</span>
        <span><i class="bi bi-gem"></i> Jewelry</span>
        <span><i class="bi bi-lamp"></i> Home Décor</span>
        <span><i class="bi bi-palette"></i> Cosmetics</span>
        <span><i class="bi bi-handbag"></i> Women's Dresses</span>
        <span><i class="bi bi-house"></i> Household</span>
        <span><i class="bi bi-droplet"></i> Skincare</span>
        <span><i class="bi bi-gem"></i> Jewelry</span>
        <span><i class="bi bi-lamp"></i> Home Décor</span>
    </div>
</div>
