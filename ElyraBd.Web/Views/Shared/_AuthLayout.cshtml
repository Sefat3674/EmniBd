<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EmniBd</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <div class="auth-shell">
        <aside class="auth-brand-panel">
            <div class="auth-brand-gradient" aria-hidden="true"></div>
            <div class="auth-grid-pattern" aria-hidden="true"></div>
            <div class="auth-orb auth-orb-1" aria-hidden="true"></div>
            <div class="auth-orb auth-orb-2" aria-hidden="true"></div>
            <div class="auth-orb auth-orb-3" aria-hidden="true"></div>

            <partial name="_AuthProductShowcase" />

            <div class="auth-brand-inner">
                <a asp-controller="Home" asp-action="Index" class="auth-logo">
                    <span class="auth-logo-mark">E</span>
                    <span class="auth-logo-text">Emni<span class="auth-logo-accent">Bd</span></span>
                </a>

                <div class="auth-brand-badge">
                    <i class="bi bi-lightning-charge-fill"></i>
                    Bangladesh's #1 growing marketplace
                </div>

                <h1 class="auth-brand-title">
                    Shop smarter.<br />
                    <span>Live better.</span>
                </h1>
                <p class="auth-brand-subtitle">
                    Cosmetics, women's fashion, household essentials &amp; more — delivered to your door.
                </p>

                <ul class="auth-features">
                    <li>
                        <span class="auth-feature-icon"><i class="bi bi-shield-lock-fill"></i></span>
                        Bank-grade security &amp; encrypted payments
                    </li>
                    <li>
                        <span class="auth-feature-icon"><i class="bi bi-truck"></i></span>
                        Fast delivery across all 64 districts
                    </li>
                    <li>
                        <span class="auth-feature-icon"><i class="bi bi-patch-check-fill"></i></span>
                        Verified sellers &amp; authentic reviews
                    </li>
                </ul>

                <div class="auth-stats">
                    <div class="auth-stat">
                        <strong>50K+</strong>
                        <span>Happy customers</span>
                    </div>
                    <div class="auth-stat">
                        <strong>10K+</strong>
                        <span>Products listed</span>
                    </div>
                    <div class="auth-stat">
                        <strong>4.9</strong>
                        <span>Average rating</span>
                    </div>
                </div>
            </div>
        </aside>

        <main class="auth-form-panel">
            <div class="auth-form-bg" aria-hidden="true"></div>
            <partial name="_AuthFormProductBg" />
            <div class="auth-form-container">
                @RenderBody()
            </div>
            <p class="auth-footer-note">
                &copy; @DateTime.UtcNow.Year EmniBd · Secure shopping for Bangladesh
            </p>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/auth.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
