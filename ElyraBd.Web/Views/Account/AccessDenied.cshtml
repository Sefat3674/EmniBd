@{
    ViewData["Title"] = "Access denied";
    Layout = "_AuthLayout";
}

<div class="auth-mobile-logo">
    <a asp-controller="Home" asp-action="Index" class="auth-logo text-decoration-none d-inline-flex">
        <span class="auth-logo-mark">E</span>
        <span class="auth-logo-text">Elyra<span class="auth-logo-accent">Bd</span></span>
    </a>
</div>

<div class="auth-card text-center">
    <div class="auth-card-icon mx-auto" style="background: linear-gradient(135deg, #ef4444, #f97316);">
        <i class="bi bi-shield-exclamation"></i>
    </div>
    <h2 class="h4 fw-bold mb-2">Access denied</h2>
    <p class="text-muted mb-4">You don't have permission to view this page.</p>
    <a asp-controller="Home" asp-action="Index" class="btn auth-btn-primary d-inline-flex align-items-center justify-content-center" style="width: auto; padding-left: 2rem; padding-right: 2rem;">
        <i class="bi bi-house me-2"></i>Back to home
    </a>
</div>
