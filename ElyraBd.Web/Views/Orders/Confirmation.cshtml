@model OrderDetailDto
@{
    ViewData["Title"] = "Order Confirmed";
}
<link rel="stylesheet" href="~/css/shop.css" asp-append-version="true" />

<div class="container py-5 text-center">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill text-success display-1"></i>
    </div>
    <h1 class="fw-bold mb-2">Thank you for your order!</h1>
    <p class="text-muted mb-4">Your order <strong>@Model.OrderNumber</strong> has been placed successfully.</p>
    <p class="mb-4">We'll notify you when your order ships. Total: <strong class="text-primary">৳@Model.TotalAmount.ToString("N2")</strong></p>
    <div class="d-flex justify-content-center gap-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary">Track order</a>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary">Continue shopping</a>
    </div>
</div>
