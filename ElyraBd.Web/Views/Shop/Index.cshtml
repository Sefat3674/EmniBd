@model IReadOnlyList<ProductDto>
@{
    ViewData["Title"] = "Shop";
    var featured = ViewBag.Featured as IReadOnlyList<ProductDto>;
    var onSale = ViewBag.OnSale as IReadOnlyList<ProductDto>;
    var categories = ViewBag.Categories as IReadOnlyList<ElyraBd.Application.DTOs.Categories.CategoryDto>;
    var searchTerm = ViewBag.SearchTerm as string;
    var categoryId = ViewBag.CategoryId as int?;
}

<link rel="stylesheet" href="~/css/shop.css" asp-append-version="true" />

<section class="shop-hero">
    <div class="container">
        <h1 class="fw-bold mb-2">Discover <span class="text-primary">ElyraBd</span></h1>
        <p class="text-muted mb-3">Cosmetics, fashion, household &amp; more</p>
        <form method="get" class="shop-search">
            <div class="input-group input-group-lg">
                <input type="text" name="q" value="@searchTerm" class="form-control" placeholder="Search products..." />
                <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
            </div>
        </form>
        @if (categories is not null)
        {
            <div class="mt-3">
                <a asp-action="Index" class="category-pill @(categoryId == null ? "active" : "")">All</a>
                @foreach (var cat in categories)
                {
                    <a asp-action="Index" asp-route-categoryId="@cat.Id" class="category-pill @(categoryId == cat.Id ? "active" : "")">@cat.Name</a>
                }
            </div>
        }
    </div>
</section>

<div class="container pb-5">
    @if (featured?.Any() == true && string.IsNullOrEmpty(searchTerm) && !categoryId.HasValue)
    {
        <h2 class="section-title-shop">Featured</h2>
        <div class="row g-4 mb-5">
            @foreach (var p in featured)
            {
                <div class="col-6 col-md-3">@await Html.PartialAsync("_ProductCard", p)</div>
            }
        </div>
    }

    @if (onSale?.Any() == true && string.IsNullOrEmpty(searchTerm) && !categoryId.HasValue)
    {
        <h2 class="section-title-shop">On sale</h2>
        <div class="row g-4 mb-5">
            @foreach (var p in onSale)
            {
                <div class="col-6 col-md-3">@await Html.PartialAsync("_ProductCard", p)</div>
            }
        </div>
    }

    <h2 class="section-title-shop">@(string.IsNullOrEmpty(searchTerm) ? "All products" : $"Results for \"{searchTerm}\"")</h2>
    @if (!Model.Any())
    {
        <p class="text-muted">No products found.</p>
    }
    else
    {
        <div class="row g-4">
            @foreach (var p in Model)
            {
                <div class="col-6 col-md-3">@await Html.PartialAsync("_ProductCard", p)</div>
            }
        </div>
    }
</div>
