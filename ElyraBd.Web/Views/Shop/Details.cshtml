@model ProductDetailDto
@{
    ViewData["Title"] = Model.Name;
}
<link rel="stylesheet" href="~/css/shop.css" asp-append-version="true" />

<div class="container py-4">
    <div class="row g-4">
        <div class="col-md-6">
            <div class="product-detail-img">
                @if (Model.ImageUrls.Any())
                {
                    <img src="@Model.ImageUrls.First()" alt="@Model.Name" />
                }
                else
                {
                    <i class="bi bi-image display-1 text-secondary"></i>
                }
            </div>
        </div>
        <div class="col-md-6">
            <p class="text-muted mb-1">@Model.CategoryName</p>
            <h1 class="fw-bold">@Model.Name</h1>
            @if (Model.ReviewCount > 0)
            {
                <p class="text-warning"><i class="bi bi-star-fill"></i> @Model.AverageRating.ToString("0.0") · @Model.ReviewCount reviews</p>
            }
            <div class="mb-3">
                <span class="fs-3 fw-bold text-primary">৳@Model.SalePrice.ToString("N2")</span>
                @if (Model.HasDiscount)
                {
                    <span class="text-muted text-decoration-line-through ms-2">৳@Model.Price.ToString("N2")</span>
                    <span class="badge bg-danger ms-2">@Model.DiscountPercent% OFF</span>
                }
            </div>
            <p class="text-muted">@Model.Description</p>
            <p><strong>Stock:</strong> @Model.Stock available</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary">← Back to shop</a>
        </div>
    </div>
    @if (Model.Reviews.Any())
    {
        <hr class="my-5" />
        <h4 class="fw-bold mb-3">Customer reviews</h4>
        @foreach (var r in Model.Reviews)
        {
            <div class="border rounded p-3 mb-2">
                <strong>@r.UserName</strong>
                <span class="text-warning ms-2">@string.Concat(Enumerable.Repeat("★", r.Rating))</span>
                <p class="mb-0 mt-1">@r.Comment</p>
            </div>
        }
    }
</div>
